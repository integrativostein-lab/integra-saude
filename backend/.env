# ─── SERVIDOR ───
PORT=3000
NODE_ENV=development

# ─── BANCO DE DADOS PostgreSQL (Substitua pelos seus dados do Supabase) ───
DATABASE_URL=postgresql://postgres:[SUA_SENHA]@[SEU_HOST].supabase.co:5432/postgres

# ─── SEGURANÇA JWT ───
JWT_SECRET=integrativo_app_jwt_secreto_2026
JWT_EXPIRE=7d

# ─── GOOGLE LOGIN ───
GOOGLE_CLIENT_ID=SEU_GOOGLE_CLIENT_ID_AQUI
GOOGLE_CLIENT_SECRET=SEU_GOOGLE_CLIENT_SECRET_AQUI

# ─── APPLE LOGIN ───
APPLE_CLIENT_ID=SEU_APPLE_CLIENT_ID_AQUI
APPLE_CLIENT_SECRET=SUA_APPLE_CLIENT_SECRET_AQUI

# ─── WHATSAPP EVOLUTION API ───
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=SUA_CHAVE_EVOLUTION_AQUI

# ─── GATEWAYS DE PAGAMENTO (Configure apenas os que for usar) ───
PAGSEGURO_TOKEN=SEU_TOKEN_PAGSEGURO_AQUI
PAGSEGURO_EMAIL=seuemail@dominio.com

PAGBANK_TOKEN=SEU_TOKEN_PAGBANK_AQUI
PAGBANK_EMAIL=seuemail@dominio.com

ASAAS_TOKEN=SEU_TOKEN_ASAAS_AQUI
TON_TOKEN=SEU_TOKEN_TON_AQUI
MERCADOPAGO_TOKEN=SEU_TOKEN_MERCADOPAGO_AQUI
EFI_BANK_CLIENT_ID=SEU_CLIENT_ID_EFI_AQUI
EFI_BANK_CLIENT_SECRET=SEU_CLIENT_SECRET_EFI_AQUI
CIELO_MERCHANT_ID=SEU_MERCHANT_ID_CIELO_AQUI
CIELO_MERCHANT_KEY=SEU_MERCHANT_KEY_CIELO_AQUI
STONE_TOKEN=SEU_TOKEN_STONE_AQUI

# ─── NOTAS FISCAIS ───
NFE_API_URL=https://api.nfe.gov.br
NFS_E_API_URL=https://api.nfse.gov.br

# ─── CEP ───
VIACEP_URL=https://viacep.com.br/ws

# ─── RATE LIMIT ───
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── CORS (URL do Frontend) ───
FRONTEND_URL=http://localhost:5500

# ─── ENCRIPTAÇÃO ───
ENCRYPTION_KEY=integrativo_encrypt_key_32_chars_

# ─── FORNECEDORES DE REVENDA ───
REGISTRO_BR_TOKEN=SEU_TOKEN_REGISTRO_BR_AQUI
CERTISIGN_TOKEN=SEU_TOKEN_CERTISIGN_AQUI
SERASA_SSL_TOKEN=SEU_TOKEN_SERASA_AQUI

# ─── ZOHO MAIL ───
ZOHO_CLIENT_ID=SEU_CLIENT_ID_ZOHO
ZOHO_CLIENT_SECRET=SEU_CLIENT_SECRET_ZOHO
ZOHO_REFRESH_TOKEN=SEU_REFRESH_TOKEN_ZOHO